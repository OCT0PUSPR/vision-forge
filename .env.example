# vision-forge configuration. Copy to `.env` and adjust.
# All values are optional; sensible defaults apply. NEVER commit a real .env.

# --- Secrets (read from environment; placeholders only here) ---
# HuggingFace token, used only when pulling gated/private models.
HF_TOKEN=your_hf_token_here

# --- Inference defaults (prefix VF_) ---
VF_DEVICE=auto              # auto | cpu | cuda | mps
VF_CONF_THRESHOLD=0.25
VF_IOU_THRESHOLD=0.45
VF_MAX_DETECTIONS=300
VF_IMAGE_SIZE=640

# --- From-scratch CenterNet detector (DEFAULT detection backend) ---
VF_DEFAULT_DETECTOR=centernet          # centernet | baseline (yolo) | hf | onnx
VF_CENTERNET_CHECKPOINT=weights/centernet_shapes.pt
VF_CENTERNET_ONNX_PATH=weights/centernet_shapes.onnx
VF_CENTERNET_CONF=0.30
VF_CENTERNET_IOU=0.50
VF_CENTERNET_IMAGE_SIZE=256
VF_CENTERNET_TOPK=100

# --- Baseline model identifiers (auto-downloaded at runtime) ---
VF_DETECTION_MODEL=yolov8n.pt
VF_SEGMENTATION_MODEL=yolov8n-seg.pt
VF_POSE_MODEL=yolov8n-pose.pt
VF_TRACKING_MODEL=yolov8n.pt
VF_CLASSIFICATION_MODEL=google/vit-base-patch16-224
VF_HF_DETECTION_MODEL=facebook/detr-resnet-50

# --- Tracking ---
VF_TRACKER=bytetrack.yaml

# --- Server ---
VF_HOST=0.0.0.0
VF_PORT=8000
VF_CORS_ORIGINS=*
VF_MAX_UPLOAD_MB=25
